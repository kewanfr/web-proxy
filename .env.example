# Copier ce fichier en .env et adapter les valeurs

# Port exposé sur l'hôte (ton reverse proxy (Caddy/Nginx/Traefik) pointera ici)
HOST_PORT=3000

# Active HTTPS direct dans le conteneur (true/false)
HTTPS_ENABLED=false

# Chemins vers les fichiers PEM dans le conteneur
# Exemple avec volume: ./certs:/certs:ro
SSL_KEY_PATH=/certs/privkey.pem
SSL_CERT_PATH=/certs/fullchain.pem

# Optionnel: chaîne CA intermédiaire
# SSL_CA_PATH=/certs/chain.pem
